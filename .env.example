# Bot Configuration
BOT_TOKEN=

# Weather APIs
QWEATHER_API_KEY=

# 和风天气新 API Host 使用根地址，不要带 /v7 或 /geo/v2
# 建议使用控制台分配的专属 Host，例如 https://abc1234xyz.def.qweatherapi.com
QWEATHER_API_HOST=https://your-qweather-host.qweatherapi.com
QWEATHER_DAILY_DAYS=7d
QWEATHER_HOURLY_HOURS=24h
QWEATHER_INDICES_TYPES=1,2,3,5,9
QWEATHER_ENABLE_MINUTELY=true

# 彩云天气可选增强源。开启后优先使用彩云分钟级降水；关闭后使用和风补全。
ENABLE_CAIYUN_API=false
CAIYUN_API_TOKEN=



# Redis Configuration (Optional, defaults to localhost)
REDIS_URL=redis://localhost:6379/0

# Logging
LOG_LEVEL=INFO

# Super Admin (Optional)
# SUPER_ADMIN_ID=123456789

# Feature Flags
ENABLE_WEATHER_PLOTS=true
# 定时任务开关。关闭后不会出现每 5 分钟 rain check 日志，也不会推送对应订阅。
ENABLE_RAIN_ALERTS=true
ENABLE_DAILY_BRIEF=true

# LLM Configuration (AI Weather Report)
# ------------------------------------------------
LLM_STREAMING=true
# Provider: 'openai' or 'gemini'
LLM_PROVIDER=openai

# Legacy fallback model if provider-specific model is not set
# LLM_MODEL=gpt-5.5

# OpenAI Config
OPENAI_API_KEY=
# OPENAI_API_BASE=https://api.openai.com/v1 (通常需要带 /v1)
OPENAI_MODEL=gpt-5.5
# OpenAI API mode: 'responses' (recommended for GPT-5.5) or 'chat_completions'
OPENAI_API_MODE=responses
# Reasoning effort: none, minimal, low, medium, high, xhigh
OPENAI_REASONING_EFFORT=medium
# Response verbosity: low, medium, high
OPENAI_VERBOSITY=medium
# Optional. Leave unset unless you explicitly need sampling control.
# OPENAI_TEMPERATURE=0.7
# OpenAI HTTP timeout and report-level timeout. Lower values make slow LLM calls fail faster.
OPENAI_TIMEOUT_SECONDS=40
LLM_REPORT_TIMEOUT_SECONDS=35
# Limit response size for faster weather reports. Leave empty to let provider decide.
OPENAI_MAX_OUTPUT_TOKENS=900

# AI 天气日报提示词。默认内置一版 Telegram HTML + emoji 分块排版提示词。
# 直接配置时用 \n 表示换行；优先级高于 LLM_WEATHER_REPORT_PROMPT_FILE。
# LLM_WEATHER_REPORT_PROMPT=你是 Domo，一个会排版的天气助手。\n只输出正文，不要标题。\n第一行必须是：当前时间：MM月DD日 HH:MM。\n使用 Telegram HTML，只允许 <b> 和 <i>。\n按以下块输出：🌤️ <b>现在</b>、⏱️ <b>接下来</b>、👕 <b>建议</b>、🌈 收尾。\n每块之间空一行，每块 1-2 句，必须基于 JSON 数据，不要编造。
# 长提示词建议放文件，例如挂载到容器 /app/prompts/weather_report.txt
# LLM_WEATHER_REPORT_PROMPT_FILE=/app/prompts/weather_report.txt

# Gemini Config
GEMINI_API_KEY=
# GEMINI_API_BASE=https://generativelanguage.googleapis.com (注意: 不要带 /v1beta, SDK会自动拼接)
GEMINI_MODEL=gemini-2.5-flash


# Webhook Configuration (Optional, for production deployment)
# ------------------------------------------------
# Bot运行模式: 'polling' (默认, 适合开发) 或 'webhook' (适合生产)
BOT_MODE=polling

# Webhook 配置 (仅在 BOT_MODE=webhook 时需要)
# WEBHOOK_URL=https://yourdomain.com
# WEBHOOK_PORT=8443
# WEBHOOK_PATH=/webhook
# WEBHOOK_SECRET=
