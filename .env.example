# Bot Configuration
BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Weather APIs
QWEATHER_API_KEY=your_hefeng_key_here

# 和风天气 Host 配置 (请根据您的订阅类型选择)
# 免费订阅 (Free): https://devapi.qweather.com/v7/
# 商业订阅 (Paid): https://api.qweather.com/v7/
QWEATHER_API_HOST=https://api.qweather.com/v7/

CAIYUN_API_TOKEN=your_caiyun_token_here



# Redis Configuration (Optional, defaults to localhost)
REDIS_URL=redis://localhost:6379/0

# Logging
LOG_LEVEL=INFO

# Super Admin (Optional)

# LLM Configuration (AI Weather Report)
# ------------------------------------------------
# Provider: 'openai' or 'gemini'
LLM_PROVIDER=openai

# Model: e.g. gpt-5, gemini-3-flash-preview
LLM_MODEL=gpt-5

# OpenAI Config
OPENAI_API_KEY=sk-your-key
# OPENAI_API_BASE=https://api.openai.com/v1 (通常需要带 /v1)

# Gemini Config
GEMINI_API_KEY=your-gemini-key
# GEMINI_API_BASE=https://generativelanguage.googleapis.com (注意: 不要带 /v1beta, SDK会自动拼接)


# Webhook Configuration (Optional, for production deployment)
# ------------------------------------------------
# Bot运行模式: 'polling' (默认, 适合开发) 或 'webhook' (适合生产)
BOT_MODE=polling

# Webhook 配置 (仅在 BOT_MODE=webhook 时需要)
# WEBHOOK_URL=https://yourdomain.com
# WEBHOOK_PORT=8443
# WEBHOOK_PATH=/webhook
# WEBHOOK_SECRET=your-random-secret-token
